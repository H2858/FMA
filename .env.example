# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY=MY_OPENROUTER_API_KEY

# SUPABASE_URL: The base URL for your Supabase project.
SUPABASE_URL=MY_SUPABASE_URL

# SUPABASE_ANON_KEY: The anonymous API key for your Supabase project.
SUPABASE_ANON_KEY=MY_SUPABASE_ANON_KEY

# SUPABASE_SERVICE_ROLE_KEY: The service role key for Supabase (if needed).
SUPABASE_SERVICE_ROLE_KEY=MY_SUPABASE_SERVICE_ROLE_KEY

# ELEVENLABS_API_KEY: Required for ElevenLabs Text-to-Speech API.
ELEVENLABS_API_KEY=MY_ELEVENLABS_API_KEY

